#!/usr/bin/env bash
# install_minio — idempotent local MinIO installer for dev mode.
#
# Downloads the MinIO server binary + mc client to /usr/local/bin/ if they're
# not already present.  Called by run_mvtrx.sh when GENTRX_ENABLED=1 and the
# GENTRX_VALIDATOR_S3_* env vars are unset/empty (i.e. dev mode wants a local
# S3 backend, not a remote one).
#
# Skips silently if MinIO is already installed (any standalone binary on PATH,
# or TAOS_MINIO_BIN points at one).
#
# Authorisation: dev box owner has asked the launcher to auto-install MinIO
# for local-dev configs ("create one and wire up run_mvtrx/validator to
# download, install and run in dev mode"). Production env files supply their
# own GENTRX_VALIDATOR_S3_* and skip this path.
#
# Usage: bin/install_minio [<install-dir>]
#   install-dir defaults to /usr/local/bin (overridable via MINIO_INSTALL_DIR).

set -eu

ARCH=$(uname -m)
case "$ARCH" in
    x86_64)  PKG_ARCH=amd64 ;;
    aarch64) PKG_ARCH=arm64 ;;
    *) echo "ERROR: unsupported arch '$ARCH' for MinIO autoinstall" >&2; exit 1 ;;
esac

INSTALL_DIR="${1:-${MINIO_INSTALL_DIR:-/usr/local/bin}}"
MINIO_URL="${MINIO_DOWNLOAD_URL:-https://dl.min.io/server/minio/release/linux-${PKG_ARCH}/minio}"
MC_URL="${MC_DOWNLOAD_URL:-https://dl.min.io/client/mc/release/linux-${PKG_ARCH}/mc}"
# MinIO publishes a companion .sha256sum file for every release binary. We fetch
# it over the same TLS connection and check the binary against it before
# installing. Defends against bit-flips, incomplete downloads, and single-resource
# MITM (e.g. CDN cache poisoning that misses the sha256sum sibling). For stronger
# guarantees pin a known-good hash via MINIO_EXPECTED_SHA256 / MC_EXPECTED_SHA256.
MINIO_SHA_URL="${MINIO_SHA_URL:-${MINIO_URL}.sha256sum}"
MC_SHA_URL="${MC_SHA_URL:-${MC_URL}.sha256sum}"

# Already-installed checks (TAOS_MINIO_BIN override, PATH, common locations)
_have_minio() {
    if [ -n "${TAOS_MINIO_BIN:-}" ] && [ -x "$TAOS_MINIO_BIN" ]; then return 0; fi
    command -v minio >/dev/null 2>&1 && return 0
    [ -x "$INSTALL_DIR/minio" ] && return 0
    return 1
}
_have_mc() {
    command -v mc >/dev/null 2>&1 && return 0
    [ -x "$INSTALL_DIR/mc" ] && return 0
    return 1
}

# _verify_sha <binary-path> <sha-url> <expected-override>
# Returns 0 on match, exits 1 on mismatch.
_verify_sha() {
    local bin="$1" sha_url="$2" expected_override="$3"
    local expected
    if [ -n "$expected_override" ]; then
        expected="$expected_override"
    else
        expected=$(curl -fsSL --retry 3 --connect-timeout 30 "$sha_url" | awk '{print $1}')
        if [ -z "$expected" ]; then
            echo "ERROR: could not fetch SHA256 from $sha_url" >&2
            exit 1
        fi
    fi
    local actual
    actual=$(sha256sum "$bin" | awk '{print $1}')
    if [ "$expected" != "$actual" ]; then
        echo "ERROR: SHA256 mismatch for $bin" >&2
        echo "  expected: $expected" >&2
        echo "  got:      $actual" >&2
        rm -f "$bin"
        exit 1
    fi
    echo "  sha256 OK: $actual"
}

if _have_minio && _have_mc; then
    echo "  MinIO + mc already installed (skipping download)"
    exit 0
fi

mkdir -p "$INSTALL_DIR"

if ! _have_minio; then
    echo "  Downloading MinIO server from $MINIO_URL..."
    curl -fL --retry 3 --connect-timeout 30 -o "$INSTALL_DIR/minio.tmp" "$MINIO_URL"
    _verify_sha "$INSTALL_DIR/minio.tmp" "$MINIO_SHA_URL" "${MINIO_EXPECTED_SHA256:-}"
    chmod +x "$INSTALL_DIR/minio.tmp"
    mv "$INSTALL_DIR/minio.tmp" "$INSTALL_DIR/minio"
    echo "  MinIO server: $($INSTALL_DIR/minio --version 2>&1 | head -1)"
fi

if ! _have_mc; then
    echo "  Downloading MinIO client (mc) from $MC_URL..."
    curl -fL --retry 3 --connect-timeout 30 -o "$INSTALL_DIR/mc.tmp" "$MC_URL"
    _verify_sha "$INSTALL_DIR/mc.tmp" "$MC_SHA_URL" "${MC_EXPECTED_SHA256:-}"
    chmod +x "$INSTALL_DIR/mc.tmp"
    mv "$INSTALL_DIR/mc.tmp" "$INSTALL_DIR/mc"
    echo "  MinIO client: $($INSTALL_DIR/mc --version 2>&1 | head -1)"
fi

echo "  MinIO installed to $INSTALL_DIR"
